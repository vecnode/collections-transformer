ENVIRONMENT="dev" # dev | prod
LOG_LEVEL="INFO" # DEBUG | INFO | WARNING | ERROR

# Server (containerized API/worker)
API_HOST="0.0.0.0"
API_PORT="8080"
API_RELOAD="false"
SECRET_KEY="local-dev-secret-key-change-in-production"
CORS_ORIGINS="http://localhost,http://127.0.0.1"

# Datastores (container network service names)
MONGODB_URI="mongodb://mongodb:27017"
MONGODB_DATABASE="tanc_database"
REDIS_URL="redis://redis:6379/0"
UPLOAD_FOLDER="/cache"

# Client (browser should go through Caddy in docker mode)
NEXT_PUBLIC_SERVER_URL="http://localhost"

# Ollama text provider (reachable from containers)
OLLAMA_MODEL_OPTION="gemma3:27b"
OLLAMA_BASE_URL="http://host.docker.internal:11434"

# Blip2 image provider
BLIP2_MODEL_NAME="Salesforce/blip2-opt-2.7b"

# Runtime toggles for PyTorch debugging
CUDA_LAUNCH_BLOCKING="1"
PYTORCH_USE_CUDA_DSA="1"
