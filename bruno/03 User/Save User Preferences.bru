meta {
  name: Save User Preferences
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/v1/backend/user/preferences
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "user_id": "{{userId}}",
    "text_provider": "ollama"
  }
}
