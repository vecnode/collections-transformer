ENVIRONMENT="dev" # dev | prod
LOG_LEVEL="INFO" # DEBUG | INFO | WARNING | ERROR

# Flask server
API_HOST="0.0.0.0"
API_PORT="8080"
FLASK_DEBUG="true"
FLASK_RELOAD="false"
FLASK_SECRET_KEY="local-dev-secret-key-change-in-production"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# MongoDB
MONGODB_URI="mongodb://127.0.0.1:27017"
MONGODB_DATABASE="tanc_database"
UPLOAD_FOLDER="/cache"

# OpenAI text provider
OPENAI_API_KEY=""
OPENAI_API_TYPE="openai"
OPENAI_MODEL_OPTION="gpt-4o"

# Ollama text provider
OLLAMA_MODEL_OPTION="gemma3:27b"
OLLAMA_BASE_URL="http://localhost:11434"

# Blip2 image provider
BLIP2_MODEL_NAME="Salesforce/blip2-opt-2.7b"

# Optional OpenRouter endpoints used by debug routes
OPENROUTER_API_KEY=""

# Runtime toggles for PyTorch debugging
CUDA_LAUNCH_BLOCKING="1"
PYTORCH_USE_CUDA_DSA="1"

